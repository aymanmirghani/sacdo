{
  "expo": {
    "name": "sacdo-app",
    "slug": "sacdo-app",
    "owner": "aymanmirghani",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sacdo.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in quickly and securely.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is required for scanning payment card details."
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.sacdo.app",
          "publishableKey": "pk_live_51TK8Jo01tmZbQrzJLrrrGtFnxC51or7dWGTVRbW7m5pvpwUidIPk2UjboavxP5wcg3F0CI2STZadsUfLF1RU6DTd00NzaszOFs"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "android": {
      "package": "com.sacdo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b7259ab1-b64f-4bf7-9624-7ec21f80f30a"
      }
    }
  }
}
